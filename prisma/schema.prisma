generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          String    @default("CLIENT")
  phone         String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  favorites     Lieu[]    @relation("UserFavorites")      // Relation avec Lieu
  createdLieux  Lieu[]    @relation("Creator")            // Relation avec Lieu
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lieu {
  id          String   @id @default(cuid())
  nom         String
  region      String
  description String
  images      String   // JSON string
  lat         Float
  lng         Float
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("Creator", fields: [createdById], references: [id])  // Relation inverse
  favoritedBy User[]   @relation("UserFavorites")                                      // Relation inverse
}
model guide {
  id            String   @id @default(cuid())
  nom           String
  prenom        String
  adresse       String
  telephone     String
  circuit       String   // Le circuit choisi par le guide (ex: "Circuit Nord", "RN7", etc.)
  dateNaissance DateTime
  lieuNaissance String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}